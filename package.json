{
	"name": "n8n-nodes-ailabtools",
	"version": "0.1.0",
	"description": "n8n community node for AILabTools AI image and portrait APIs.",
	"license": "MIT",
	"packageManager": "pnpm@11.7.0",
	"homepage": "https://www.ailabtools.com/docs",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"ailabtools",
		"ai-image",
		"image-processing"
	],
	"author": {
		"name": "AILabTools",
		"email": "support@ailabtools.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ailabtools/n8n-nodes-ailabtools.git"
	},
	"engines": {
		"node": ">=20.15"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/AilabToolsApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/AilabTools/AilabTools.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.38.8",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.2.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"pnpm": {
		"ignoredBuiltDependencies": [
			"cpu-features",
			"eslint-plugin-n8n-nodes-base",
			"isolated-vm",
			"ssh2",
			"unrs-resolver"
		]
	}
}
